{
  "name": "porfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev",
    "dev:turbo": "next dev --turbo",
    "dev:clean": "node scripts/clean-next.mjs && next dev",
    "dev:3000": "node scripts/kill-port.mjs 3000 && node scripts/clean-next.mjs && next dev -p 3000",
    "build": "next build",
    "build:preview": "cross-env NEXT_PUBLIC_BASE_PATH= next build",
    "start": "next start",
    "preview": "npm run build:preview && npx serve out -s -p 5000",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0"
  }
}
